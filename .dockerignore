# Python cache files
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments (never bake the local venv into the image)
venv/
.venv/
env/

# Environment / secrets (injected at runtime by AWS)
.env
*.env

# Git
.git/
.gitignore

# Editor and OS artefacts
.cursorignore
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Docs and tooling (not needed at runtime)
README.md
AGENTS.md


# Docker itself
Dockerfile
.dockerignore
